FROM node:22-alpine

WORKDIR /app

# Build context is the repo root; paths are relative to it.
COPY lastsaas/frontend/package.json lastsaas/frontend/package-lock.json ./

RUN npm ci

# Source is bind-mounted at runtime via docker-compose volumes.
COPY lastsaas/frontend/ .

EXPOSE 4280

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
