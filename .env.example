# =============================================================================
# SaaSCaffold — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# --- DOMAIN (production only) ---
DOMAIN=yoursite.com
CADDY_EMAIL=you@example.com

# --- MongoDB (LastSaaS backend) ---
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme_in_production
MONGO_DB_NAME=lastsaas
# Override to use MongoDB Atlas or an external instance:
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/lastsaas

# --- WordPress / MariaDB ---
WP_DB_ROOT_PASSWORD=rootpassword_change_in_prod
WP_DB_NAME=wordpress
WP_DB_USER=wp_user
WP_DB_PASSWORD=wp_password_change_in_prod

# --- LastSaaS: Authentication ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=replace_with_openssl_rand_hex_32
# Webhooks use AES-256-GCM — must be a 64-character hex string
# Generate with: openssl rand -hex 32
WEBHOOK_ENCRYPTION_KEY=replace_with_openssl_rand_hex_32

# --- LastSaaS: Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- LastSaaS: App ---
APP_NAME=YourApp
FROM_NAME=YourApp
FROM_EMAIL=noreply@yoursite.com

# --- LastSaaS: Email (Resend) ---
RESEND_API_KEY=re_...

# --- LastSaaS: OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Astro Marketing Site ---
SITE_URL=https://yoursite.com
WORDPRESS_API_URL=http://wordpress/wp-json/wp/v2

# --- Caddy production CMS auth backstop (optional, Cloudflare Zero Trust is primary) ---
# Generate password hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext yourpassword
# CMS_USER=admin
# CMS_PASSWORD_HASH=$2a$14$...
